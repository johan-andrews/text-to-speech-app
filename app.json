{
  "expo": {
    "name": "VoiceFlow AI",
    "slug": "flowvoice-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "voiceflow",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.voiceflowai",
      "associatedDomains": [
        "applinks:REPLACE_WITH_YOUR_DOMAIN"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow VoiceFlow to use the microphone.",
        "NSSpeechRecognitionUsageDescription": "Allow VoiceFlow to use speech recognition."
      }
    },
    "android": {
      "package": "com.yourcompany.voiceflowai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "androidStatusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0d0d0d",
        "translucent": true
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "voiceflow"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0d0d",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-av",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow VoiceFlow to use the microphone.",
          "speechRecognitionPermission": "Allow VoiceFlow to use speech recognition."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "73fa9eaa-c24b-4458-8204-e1e976d2d57c"
      }
    },
    "owner": "johanandrews"
  }
}
